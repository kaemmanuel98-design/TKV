# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Upload chunks → Supabase (nécessite embeddings: npm run upload:chunks:embed)
# SUPABASE_SERVICE_ROLE_KEY obligatoire pour upload et seed
# Dev local uniquement — proxy Vite vers :3001
# VITE_API_URL=http://localhost:3001
# Production Vercel : ne pas définir VITE_API_URL (même origine /api)

# API Agent (server/index.js)
API_PORT=3001
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
# Lecture vocale naturelle (POST /api/tts) — utilise la même clé OpenAI
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RAG_SIMILARITY_THRESHOLD=0.72
RAG_TOP_K=5

# Visio cellules (Jitsi auto-hébergé + JWT) — valeurs dans jitsi-local-credentials.txt après setup
JITSI_DOMAIN=localhost
JITSI_PUBLIC_URL=https://localhost:8443
JITSI_JWT_SUB=localhost
JITSI_APP_ID=your_jitsi_app_id
JITSI_APP_SECRET=your_jitsi_jwt_secret
JITSI_ROOM_SECRET=random_room_name_secret
# Dev uniquement (non sécurisé) :
# JITSI_ALLOW_PUBLIC_FALLBACK=true

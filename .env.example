# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Upload chunks → Supabase (nécessite embeddings: npm run upload:chunks:embed)
# SUPABASE_SERVICE_ROLE_KEY obligatoire pour upload et seed
# Dev local uniquement — proxy Vite vers :3001
# VITE_API_URL=http://localhost:3001
# Production Vercel : ne pas définir VITE_API_URL (même origine /api)

# API Agent (server/index.js)
API_PORT=3001
# Production : origines autorisées (virgules), ex. https://tkv-app.vercel.app
# CORS_ORIGINS=https://tkv-app.vercel.app
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
# Lecture vocale naturelle (POST /api/tts) — utilise la même clé OpenAI
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RAG_SIMILARITY_THRESHOLD=0.72
RAG_TOP_K=5

# Animateur de cellules (création sans Premium+) — profil Supabase :
#   exécuter supabase_profiles_can_host_visio.sql puis :
#   UPDATE profiles SET can_host_visio = true WHERE id = '<votre-uuid>';
# Secours par e-mail (optionnel) :
# JITSI_HOST_EMAILS=votre@email.com
# Premium+ : plan_type = premium_plus (création de cellule automatique)

# Confessionnal — chiffrement AES-256 des messages en base (min. 16 caractères)
# CONFESSIONAL_ENCRYPTION_KEY=change-me-long-random-secret
# Dashboard accompagnateur (/companion) :
#   exécuter supabase_companion_dashboard.sql
#   UPDATE profiles SET is_confessional_companion = true WHERE id = '<uuid>';
# COMPANION_HOST_EMAILS=accompagnateur@email.com
# COMPANION_REQUIRE_MFA=true

# Paiements Premium (voir docs/PAYMENTS.md)
APP_PUBLIC_URL=http://localhost:5173
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
# Wave — désactivé pour l’instant (réactiver plus tard, voir docs/PAYMENTS.md)
# WAVE_API_KEY=
# WAVE_WEBHOOK_SECRET=
# PREMIUM_AMOUNT_XOF=6500
# PREMIUM_PLUS_AMOUNT_XOF=9500
PREMIUM_AMOUNT_EUR_CENTS=999
PREMIUM_PLUS_AMOUNT_EUR_CENTS=1499
PREMIUM_DURATION_DAYS=30
PAYMENT_SANDBOX=true
PAYMENT_DEV_SECRET=dev-only-secret
